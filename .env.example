# ─────────────────────────────────────────────────────────────────────────────
# TipidTips.ph — environment variables
# Kopyahin ito sa `.env.local` (gitignored) at punan ng totoong values.
#   cp .env.example .env.local
# ─────────────────────────────────────────────────────────────────────────────

# ── Firebase (REQUIRED) ──────────────────────────────────────────────────────
# Galing sa Firebase console → Project settings → Your apps → Web app config.
# Naka-prefix ng VITE_ para ma-expose sa client bundle (normal sa Firebase web).
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── AI tip + prediction generator (scripts/generateLocationTips.ts) ──────────
# Groq ang primary (libre, mabilis). Kung walang Groq, Gemini ang fallback.
# Kahit isa lang dito ay sapat na; kung wala, gracefully ni-skip ang generation.
GROQ_API_KEY=
GEMINI_API_KEY=

# ── Vlog link enricher (scripts/enrichVlogLinks.ts) — OPTIONAL ───────────────
# Gemini lang ang kailangan (gumagamit ng built-in Google Search).
# Optional na alternatives kung gusto mo:
#   ANTHROPIC_API_KEY    — Claude para pumili ng best URL (paid, mas accurate)
#   BRAVE_SEARCH_API_KEY — Brave Search API (free tier ~2k/month)
ANTHROPIC_API_KEY=
BRAVE_SEARCH_API_KEY=
